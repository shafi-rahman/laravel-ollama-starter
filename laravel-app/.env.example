APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ────────────────────────────────────────────────────────────────
# Option 1: SQLite (zero config, great for quick local testing)
# DB_CONNECTION=sqlite

# Option 2: MySQL (recommended for full local setup)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=open_claw
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# ── AI / Ollama ──────────────────────────────────────────────────────────────
AI_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=phi

# Required: set any secret string — sent as X-API-Key header on every request
AI_API_KEY=

# Context window size — LOWER THIS if your laptop hangs or runs out of RAM
# 2048 = ~1.5 GB RAM, 4096 = ~4 GB, default Ollama is model-dependent
OLLAMA_NUM_CTX=2048

# Max tokens per response — lower = faster replies, higher = longer answers
OLLAMA_NUM_PREDICT=512

# ── Docker Compose (optional) ────────────────────────────────────────────────
# These are read by docker-compose.yml when running via Docker.
# Copy to a .env file at the ROOT of the repo (not inside laravel-app/).
# MYSQL_ROOT_PASSWORD=changeme
# MYSQL_DATABASE=open_claw
